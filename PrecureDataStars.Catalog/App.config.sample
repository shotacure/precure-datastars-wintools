<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    PrecureDataStars.Catalog（音楽・映像カタログ管理 GUI）の接続文字列および外部 API 設定。
    このファイルを App.config にコピーして自分の環境に合わせて設定してください。
    .gitignore は **/App.config を除外しているため、本サンプルだけがリポジトリに残ります。
  -->
  <connectionStrings>
    <add name="DatastarsMySql"
         connectionString="Server=localhost;Port=3306;Database=precure_datastars;Uid=YOUR_USER;Pwd=YOUR_PASSWORD;CharSet=utf8mb4;"
         providerName="MySqlConnector" />
  </connectionStrings>

  <appSettings>
    <!--
      Amazon Creators API の認証情報。
      Associates Central > Tools > Creators API でアプリケーションを作成し、Credential ID / Credential Secret /
      Version の 3 値を発行する。下記 4 つすべて（PartnerTag 含む）を設定すると、商品エディタの「検索...」ボタンから
      商品名で ASIN を検索するダイアログが有効になり、「画像取得」ボタンでの一括取得も Creators API
      （amazon_cd / amazon_digital）で動く。1 つでも空文字なら両機能とも無効化される。
    -->
    <add key="PaApi.CredentialId"     value="" />
    <add key="PaApi.CredentialSecret" value="" />
    <!-- Version: 2.1/2.2/2.3（Cognito 経由）または 3.1/3.2/3.3（Login with Amazon 経由）。
         日本（FE）は 2.3 か 3.3。Associates Central の発行画面に表示された値をそのまま貼る。 -->
    <add key="PaApi.CredentialVersion" value="" />
    <add key="PaApi.PartnerTag"        value="" />

    <!--
      マーケットプレイスドメイン。日本の Amazon を使う場合は下記固定値。他国（米 amazon.com など）に
      切り替えたい場合のみ書き換える。Creators API のクレデンシャル自体はグローバルに使えるが、API 呼び出しの
      x-marketplace ヘッダおよびリクエストボディの marketplace フィールドにこの値が乗る。
    -->
    <add key="PaApi.Marketplace" value="www.amazon.co.jp" />
  </appSettings>
</configuration>
