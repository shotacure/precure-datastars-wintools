<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<!--
		PrecureDataStars.SiteBuilder の接続文字列・出力先設定サンプル。
		運用時はこのファイルを App.config にコピーし、各値を環境に合わせて書き換える。
		.gitignore は **/App.config を除外しているため、本サンプルだけがリポジトリに残る。
	-->
	<connectionStrings>
		<add name="DatastarsMySql"
			 connectionString="Server=127.0.0.1;Port=3306;Database=precure_datastars;User Id=YOUR_USER;Password=YOUR_PASSWORD;Allow User Variables=true;CharSet=utf8mb4;TreatTinyAsBoolean=true" />
	</connectionStrings>

	<appSettings>
		<!--
			生成済みサイトの出力先ディレクトリ（絶対パス推奨。相対なら実行時カレントから解決）。
			ビルドモードはコマンドライン引数で決まる（引数なし＝テスト、"production" オプション付き＝本番）。
			SiteOutputDir     : 本番モードの出力先。未設定時は exe 直下 "out/site/"。
			SiteOutputDirTest : テストモード（既定）の出力先。未設定時は exe 直下 "out/site-test/"。
			テストモードでは GA4 / AdSense のタグと ads.txt を出力しない（ID は設定したままでよい）。
		-->
		<add key="SiteOutputDir" value="" />
		<add key="SiteOutputDirTest" value="" />

		<!--
			生成サイトのベース URL（末尾スラッシュなし）。
			canonical / OGP / sitemap.xml の絶対 URL 組み立てに使用。
			未設定時は空文字（相対パスでの canonical 生成にフォールバック）。
		-->
		<add key="SiteBaseUrl" value="https://precure.tv" />

		<!--
			生成サイトの表示タイトル（ヘッダ・ブラウザタブに使う）。
		-->
		<add key="SiteName" value="precure-datastars" />

		<!--
			Google Analytics 4 のメジャメント ID（例: G-XXXXXXXXXX）。
			設定すると全 HTML ページの <head> に gtag.js のローダ + gtag('config', '<ID>') の
			2 段が出力され、サイト全体のアナリティクストラッキングが有効になる。
			実際に出力されるのは本番モード起動時のみ（テストモードでは設定したままでも出力されない）。
			未設定時は本番モードでも GA4 タグを出力しない。
		-->
		<add key="Ga4MeasurementId" value="" />

		<!--
			Google Search Console の所有権確認用トークン。
			Search Console から発行される <meta name="google-site-verification" content="..."> の
			content 値を設定する。設定すると全 HTML ページの <head> に確認用メタタグが出力される。
			Search Console での所有権確認が完了すれば削除して構わない（ただし残しておいても害はない）。
		-->
		<add key="GoogleSiteVerification" value="" />

		<!--
			Google AdSense のパブリッシャー ID（例: ca-pub-1234567890123456）。
			設定すると全 HTML ページの <head> に AdSense ローダスクリプトが 1 行だけ出力され、
			Google の自動広告（Auto Ads）が有効化される。広告ユニットの個別配置は不要で、
			Google が自動的にページ内の最適な位置に広告を配置する。
			実際に出力されるのは本番モード起動時のみ（テストモードでは設定したままでも出力されない）。
			未設定時は本番モードでも AdSense スクリプトを出力しない。
			本値が有効なときは、サイト接続（所有確認）用の google-adsense-account メタタグと、
			SeoGenerator による /ads.txt も併せて出力される
			（標準 1 行: google.com, pub-XXXXX, DIRECT, f08c47fec0942fa0）。
		-->
		<add key="GoogleAdSenseClientId" value="" />

		<!--
			OGP（Open Graph Protocol）の og:image に使うサイト共通既定画像。
			絶対 URL を指定する（例: https://precure.tv/og-default.png）。
			個別ページで OgImage の明示指定が無い場合に、本値が自動補完される。
			本値が設定されているときは、全ページが Twitter カード summary_large_image 形式で
			シェアされ、X / Facebook / LINE 等でのリンクプレビューが大きなカードで表示される。
			推奨サイズ：1200×630 ピクセル（最低 600×315、上限 8MB）。
			画像ファイル本体は wwwroot/ 直下に手動配置する運用（README 参照）。
			未設定時は従来通り、OgImage 未指定ページでは Twitter カードは summary（小） となる。
		-->
		<add key="DefaultOgImage" value="" />

		<!--
			サイトの公開（初公開）年。
			フッタの著作権表記「© YYYY-YYYY Shota (SHOWTIME).」の左側の年に使う。
			未設定時の既定値は 2026。
		-->
		<add key="SitePublishedYear" value="2026" />

		<!--
			Amazon アソシエイトのトラッキング ID。
			商品詳細ページの Amazon リンクに ?tag= として付与し、アフィリエイト計測に使う。
			例: yourtag-22 のような「アソシエイトタグ-数字」形式。
			未設定（空文字）の場合は Amazon リンク自体は出力するが tag を付けない。
			Creators API は使わず ASIN への正規 URL を組むだけのため、サイト審査前でも合法に貼れる。
		-->
		<add key="AmazonAssociateTag" value="" />

		<!--
			AWS デプロイ設定（production + deploy 起動時のみ使用）。
			生成済みサイトを S3 バケットへ差分同期し、CloudFront のキャッシュを無効化する。
			本サンプルには実値を書かない。運用時に App.config 側で各自の環境値を設定する。
			認証情報そのものはここには書かない。AwsProfile で指定した AWS 名前付きプロファイル
			（~/.aws/credentials、リポジトリ外）から SDK が解決する。
				AwsS3Bucket              : 同期先 S3 バケット名（例: your-bucket-name）。
				AwsRegion                : バケットのリージョン（例: ap-northeast-1）。
				AwsProfile               : 認証に使う AWS 名前付きプロファイル名（例: my-deploy-profile）。
				                           空なら SDK 既定の資格情報解決チェーンに委ねる。
				CloudFrontDistributionId : キャッシュ削除対象の Distribution ID（例: EXXXXXXXXXXXXX）。
				                           空なら invalidation をスキップ。
				AwsDeployProtectedPrefixes : 削除（orphan 掃除）対象から除外するキー接頭辞のカンマ区切り。
				                           手動配置物を守るための安全弁。通常は空でよい。
		-->
		<add key="AwsS3Bucket" value="" />
		<add key="AwsRegion" value="" />
		<add key="AwsProfile" value="" />
		<add key="CloudFrontDistributionId" value="" />
		<add key="AwsDeployProtectedPrefixes" value="" />
	</appSettings>
</configuration>
